# Copy this file to .env and fill in your values
# .env is excluded from git

DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme
FRONTEND_PORT=80
# Set to 1 to generate a new random password on next backend start; resets to 0 automatically
RESET_PWD=0
# Comma-separated IPs of this machine. Actions targeting these IPs run locally (no SSH).
# Example: LOCAL_HOST_IPS=192.168.1.41
LOCAL_HOST_IPS=
